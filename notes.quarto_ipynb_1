    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "t = np.linspace(-3, 3, 1000)\n",
    "f = np.exp(-np.pi * t**2)\n",
    "xi = np.fft.fftfreq(len(t), d=t[1]-t[0])\n",
    "fhat = np.fft.fft(f) * (t[1]-t[0])\n",
    "\n",
    "plt.plot(np.fft.fftshift(xi), np.abs(np.fft.fftshift(fhat)))\n",
    "plt.xlabel(r\"$\\xi$\")\n",
    "plt.title(\"Magnitude spectrum\")\n",
    "plt.show()"
   ]
