   "source": [
    "---\n",
    "title: \"Notes — TNB Frame\"\n",
    "---\n",
    "\n",
    "\n",
    "\n",
    "## Interactive TNB Frame Animation\n",
    "\n",
    "Enter $\\mathbf{r}(t)=\\langle x(t),y(t),z(t)\\rangle $, $a\\leq t \\leq b$ then click **Plot**. After showing the TNB frame, hitting **Play** will move the frame along the curve.\n",
    "\n",
    "::: {=html}\n",
    "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/mathjs/13.0.0/math.min.js\"></script>\n",
    "<script src=\"https://cdn.plot.ly/plotly-2.35.2.min.js\"></script>\n",
    "\n",
    "<style>\n",
    "  .tnb-input-grid { display:grid; grid-template-columns: auto 1fr; gap:.4rem .6rem;\n",
    "                    align-items:center; margin-bottom:.75rem; max-width:500px; }\n",
    "  .tnb-input-grid label { font-family:monospace; font-size:.9rem; white-space:nowrap; }\n",
    "  .tnb-input-grid input[type=\"text\"] { font-family:monospace; font-size:.9rem;\n",
    "                    padding:.35rem .55rem; border:1px solid #ccc; border-radius:4px; width:100%; }\n",
    "  #tnb-interval-row { display:flex; gap:.5rem; align-items:center; margin-bottom:.75rem; flex-wrap:wrap; }\n",
    "  #tnb-interval-row label { font-size:.9rem; }\n",
    "  #tnb-interval-row input { width:5rem; padding:.35rem .4rem; border:1px solid #ccc;\n",
    "                             border-radius:4px; font-size:.9rem; }\n",
    "  #tnb-plot-btn   { padding:.35rem 1rem; background:#0d6efd; color:#fff;\n",
    "                    border:none; border-radius:4px; cursor:pointer; font-size:.9rem; }\n",
    "  #tnb-err        { color:#c0392b; font-size:.88rem; margin-bottom:.5rem; display:none; }\n",
    "  #tnb-slider-row { display:none; align-items:center; gap:.8rem; margin-bottom:.5rem; }\n",
    "  #tnb-play-btn   { padding:.3rem .85rem; background:#198754; color:#fff;\n",
    "                    border:none; border-radius:4px; cursor:pointer; font-size:.9rem; white-space:nowrap; }\n",
    "  #tnb-toggle-btn { padding:.3rem .85rem; background:#6c757d; color:#fff;\n",
    "                    border:none; border-radius:4px; cursor:pointer; font-size:.9rem; white-space:nowrap; }\n",
    "  #tnb-t-slider   { flex:1; }\n",
    "  #tnb-t-label    { font-family:monospace; min-width:4ch; }\n",
    "  #tnb-plot       { width:100%; height:520px; }\n",
    "</style>\n",
    "\n",
    "<div class=\"tnb-input-grid\">\n",
    "  <label>x(t) =</label>\n",
    "  <input id=\"tnb-x\" type=\"text\" value=\"2*cos(3*t)\" />\n",
    "  <label>y(t) =</label>\n",
    "  <input id=\"tnb-y\" type=\"text\" value=\"2*sin(t)\" />\n",
    "  <label>z(t) =</label>\n",
    "  <input id=\"tnb-z\" type=\"text\" value=\"2*cos(2*t)\" />\n",
    "</div>\n",
    "<div id=\"tnb-interval-row\">\n",
    "  <label>a =</label>\n",
    "  <input id=\"tnb-t-a\" type=\"number\" value=\"0\" step=\"0.1\" />\n",
    "  <label>b =</label>\n",
    "  <input id=\"tnb-t-b\" type=\"number\" value=\"6.2832\" step=\"0.1\" />\n",
    "  <button id=\"tnb-plot-btn\" onclick=\"plotTNB()\">Plot</button>\n",
    "</div>\n",
    "<div id=\"tnb-err\"></div>\n",
    "<div id=\"tnb-toggle-row\" style=\"display:none; margin-bottom:.4rem;\">\n",
    "  <button id=\"tnb-toggle-btn\" onclick=\"toggleTNB()\">Show T,N,B</button>\n",
    "</div>\n",
    "<div id=\"tnb-slider-row\">\n",
    "  <button id=\"tnb-play-btn\" onclick=\"togglePlay()\">&#9654; Play</button>\n",
    "  <input id=\"tnb-t-slider\" type=\"range\" min=\"0\" max=\"1000\" value=\"0\" oninput=\"updateFrame(+this.value)\">\n",
    "  <span id=\"tnb-t-label\">0.00</span>\n",
    "</div>\n",
    "<div id=\"tnb-plot\"></div>\n",
    "\n",
    "<script>\n",
    "let _rFunc      = null;\n",
    "let _scale      = 0.5;\n",
    "let _axisLayout = {};          // fixed axis ranges, set once at plot time\n",
    "let _rafId      = null;        // requestAnimationFrame handle\n",
    "let _playStart  = null;        // timestamp when play began\n",
    "let _playOffset = 0;           // slider value (0–1000) when play began\n",
    "let _tA         = 0;           // interval start\n",
    "let _tB         = 2 * Math.PI; // interval end\n",
    "\n",
    "/* ── math helpers ── */\n",
    "function norm3(v)      { return Math.sqrt(v[0]**2 + v[1]**2 + v[2]**2); }\n",
    "function normalize3(v) { const n = norm3(v); return n > 1e-12 ? v.map(x => x/n) : [1,0,0]; }\n",
    "function cross3(a, b)  {\n",
    "  return [a[1]*b[2]-a[2]*b[1], a[2]*b[0]-a[0]*b[2], a[0]*b[1]-a[1]*b[0]];\n",
    "}\n",
    "function splitComps(raw) {\n",
    "  const parts = []; let depth = 0, cur = \"\";\n",
    "  for (const ch of raw) {\n",
    "    if      (ch === \"(\")               { depth++; cur += ch; }\n",
    "    else if (ch === \")\")               { depth--; cur += ch; }\n",
    "    else if (ch === \",\" && depth === 0){ parts.push(cur.trim()); cur = \"\"; }\n",
    "    else                               { cur += ch; }\n",
    "  }\n",
    "  if (cur.trim()) parts.push(cur.trim());\n",
    "  return parts;\n",
    "}\n",
    "\n",
    "/* ── numerical TNB frame ── */\n",
    "function makeR(comps) { return t => comps.map(expr => math.evaluate(expr, { t })); }\n",
    "function compT(r, t, h=1e-5) {\n",
    "  const r1 = r(t+h), r0 = r(t-h);\n",
    "  return normalize3(r1.map((v,i) => (v - r0[i]) / (2*h)));\n",
    "}\n",
    "function compTNB(r, t, h=1e-5) {\n",
    "  const T  = compT(r, t,   h);\n",
    "  const T1 = compT(r, t+h, h);\n",
    "  const T0 = compT(r, t-h, h);\n",
    "  const dT = T1.map((v,i) => (v - T0[i]) / (2*h));\n",
    "  const Nv = normalize3(dT);\n",
    "  return { T, N: Nv, B: cross3(T, Nv) };\n",
    "}\n",
    "\n",
    "/* ── Plotly helpers ── */\n",
    "function arrowTrace(p, v, sc, color, name) {\n",
    "  const end = p.map((x,i) => x + v[i]*sc);\n",
    "  return { type:'scatter3d', mode:'lines+markers',\n",
    "           x:[p[0],end[0]], y:[p[1],end[1]], z:[p[2],end[2]],\n",
    "           line:{color, width:6}, marker:{size:[0,6], color},\n",
    "           name, showlegend:true };\n",
    "}\n",
    "function axisRange(vals, pad=0.15) {\n",
    "  const mn = Math.min(...vals), mx = Math.max(...vals);\n",
    "  const sp = (mx - mn) || 1;\n",
    "  return [mn - sp*pad, mx + sp*pad];\n",
    "}\n",
    "\n",
    "/* ── main plot function ── */\n",
    "function plotTNB() {\n",
    "  stopPlay();\n",
    "  const errEl = document.getElementById('tnb-err');\n",
    "  errEl.style.display = 'none';\n",
    "\n",
    "  let comps;\n",
    "  try {\n",
    "    comps = [\n",
    "      document.getElementById('tnb-x').value.trim(),\n",
    "      document.getElementById('tnb-y').value.trim(),\n",
    "      document.getElementById('tnb-z').value.trim()\n",
    "    ];\n",
    "    if (comps.some(c => !c)) throw new Error('Please fill in all three components');\n",
    "    const r = makeR(comps); r(0); r(0.1);\n",
    "    _rFunc = r;\n",
    "  } catch(e) {\n",
    "    errEl.textContent = 'Error: ' + e.message;\n",
    "    errEl.style.display = 'block';\n",
    "    return;\n",
    "  }\n",
    "\n",
    "  // Read interval\n",
    "  _tA = parseFloat(document.getElementById('tnb-t-a').value);\n",
    "  _tB = parseFloat(document.getElementById('tnb-t-b').value);\n",
    "  if (isNaN(_tA) || isNaN(_tB) || _tB <= _tA) {\n",
    "    errEl.textContent = 'Error: b must be greater than a';\n",
    "    errEl.style.display = 'block';\n",
    "    return;\n",
    "  }\n",
    "\n",
    "  // Sample curve + all vector endpoints to compute fixed axis ranges\n",
    "  const nPts = 1000;\n",
    "  const ts   = Array.from({length: nPts}, (_, i) => _tA + (_tB - _tA) * i / (nPts - 1));\n",
    "  const pts  = ts.map(t => _rFunc(t));\n",
    "  const flat = pts.flat();\n",
    "  const span = Math.max(...flat) - Math.min(...flat);\n",
    "  _scale = span*0.25;\n",
    "\n",
    "  // Include vector tip positions in range calculation\n",
    "  const allX = [], allY = [], allZ = [];\n",
    "  ts.filter((_,i) => i % 10 === 0).forEach(t => {\n",
    "    const p = _rFunc(t);\n",
    "    const {T, N, B} = compTNB(_rFunc, t);\n",
    "    [T, N, B].forEach(v => {\n",
    "      allX.push(p[0], p[0]+v[0]*_scale);\n",
    "      allY.push(p[1], p[1]+v[1]*_scale);\n",
    "      allZ.push(p[2], p[2]+v[2]*_scale);\n",
    "    });\n",
    "  });\n",
    "\n",
    "  _axisLayout = {\n",
    "    margin: {l:0, r:0, t:20, b:0},\n",
    "    legend: {x:0, y:1, font: {size: 20}},\n",
    "    scene: {\n",
    "      aspectmode: 'cube',\n",
    "      xaxis: { range: axisRange(allX) },\n",
    "      yaxis: { range: axisRange(allY) },\n",
    "      zaxis: { range: axisRange(allZ) }\n",
    "    }\n",
    "  };\n",
    "\n",
    "  const p0 = _rFunc(_tA);\n",
    "  const {T, N, B} = compTNB(_rFunc, _tA);\n",
    "\n",
    "  Plotly.react('tnb-plot', [\n",
    "    { type:'scatter3d', mode:'lines',\n",
    "      x: pts.map(p=>p[0]), y: pts.map(p=>p[1]), z: pts.map(p=>p[2]),\n",
    "      line:{color:'red', width:3}, name:'r(t)', showlegend:true },\n",
    "    arrowTrace(p0, T, _scale, 'green',  'T'),\n",
    "    arrowTrace(p0, N, _scale, 'blue',   'N'),\n",
    "    arrowTrace(p0, B, _scale, 'purple', 'B'),\n",
    "  ], _axisLayout);\n",
    "\n",
    "  document.getElementById('tnb-slider-row').style.display = 'flex';\n",
    "  document.getElementById('tnb-toggle-row').style.display = 'block';\n",
    "  document.getElementById('tnb-t-slider').value = 0;\n",
    "  document.getElementById('tnb-t-label').textContent = _tA.toFixed(2);\n",
    "\n",
    "  // Default to hidden\n",
    "  _tnbVisible = false;\n",
    "  Plotly.restyle('tnb-plot', { visible: false }, [1, 2, 3]);\n",
    "  document.getElementById('tnb-toggle-btn').textContent = 'Show T,N,B';\n",
    "}\n",
    "\n",
    "/* ── frame update (called by slider and animation loop) ── */\n",
    "function updateFrame(val) {\n",
    "  if (!_rFunc) return;\n",
    "  const slider = document.getElementById('tnb-t-slider');\n",
    "  slider.value = val;\n",
    "  const t = _tA + (_tB - _tA) * val / 1000;\n",
    "  document.getElementById('tnb-t-label').textContent = t.toFixed(2);\n",
    "\n",
    "  const p = _rFunc(t);\n",
    "  const {T, N, B} = compTNB(_rFunc, t);\n",
    "  const Tend = p.map((x,i) => x + T[i]*_scale);\n",
    "  const Nend = p.map((x,i) => x + N[i]*_scale);\n",
    "  const Bend = p.map((x,i) => x + B[i]*_scale);\n",
    "\n",
    "  Plotly.update('tnb-plot',\n",
    "    { x:[[p[0],Tend[0]],[p[0],Nend[0]],[p[0],Bend[0]]],\n",
    "      y:[[p[1],Tend[1]],[p[1],Nend[1]],[p[1],Bend[1]]],\n",
    "      z:[[p[2],Tend[2]],[p[2],Nend[2]],[p[2],Bend[2]]] },\n",
    "    {}, [1, 2, 3]\n",
    "  );\n",
    "}\n",
    "\n",
    "/* ── play / pause ── */\n",
    "/* ── toggle T,N,B visibility ── */\n",
    "let _tnbVisible = true;\n",
    "function toggleTNB() {\n",
    "  _tnbVisible = !_tnbVisible;\n",
    "  Plotly.restyle('tnb-plot', { visible: _tnbVisible }, [1, 2, 3]);\n",
    "  document.getElementById('tnb-toggle-btn').textContent =\n",
    "    _tnbVisible ? 'Hide T,N,B' : 'Show T,N,B';\n",
    "}\n",
    "\n",
    "const PLAY_DURATION = 10000; // 10 seconds\n",
    "\n",
    "function togglePlay() {\n",
    "  if (_rafId) { stopPlay(); } else { startPlay(); }\n",
    "}\n",
    "function startPlay() {\n",
    "  if (!_rFunc) return;\n",
    "  _playOffset = +document.getElementById('tnb-t-slider').value;\n",
    "  // If at the end, restart from beginning\n",
    "  if (_playOffset >= 1000) _playOffset = 0;\n",
    "  _playStart = null;\n",
    "  document.getElementById('tnb-play-btn').textContent = '⏸ Pause';\n",
    "  _rafId = requestAnimationFrame(animStep);\n",
    "}\n",
    "function stopPlay() {\n",
    "  if (_rafId) { cancelAnimationFrame(_rafId); _rafId = null; }\n",
    "  const btn = document.getElementById('tnb-play-btn');\n",
    "  if (btn) btn.textContent = '▶ Play';\n",
    "}\n",
    "function animStep(timestamp) {\n",
    "  if (!_playStart) _playStart = timestamp;\n",
    "  const elapsed = timestamp - _playStart;\n",
    "  // Map elapsed time to remaining slider distance\n",
    "  const remaining = 1000 - _playOffset;\n",
    "  const progress  = Math.min(elapsed / (PLAY_DURATION * remaining / 1000), 1);\n",
    "  const val = Math.round(_playOffset + remaining * progress);\n",
    "  updateFrame(val);\n",
    "  if (val < 1000) {\n",
    "    _rafId = requestAnimationFrame(animStep);\n",
    "  } else {\n",
    "    stopPlay();\n",
    "  }\n",
    "}\n",
    "</script>\n",
    ":::\n",
    "\n",
    "---\n",
